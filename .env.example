# Copy to .env and fill in. `.env` is gitignored.

# HMAC secret for signing auth JWTs (access + refresh tokens).
# REQUIRED in production (the app fails fast if unset). Must be >= 16 chars.
# In dev/test an insecure fallback is used when this is empty.
# Generate one: `openssl rand -base64 48`
JWT_SECRET=

# SQLite database file path (optional; defaults to ./data/app.db).
# DATABASE_URL=./data/app.db

# AI assistant (TanStack AI). The provider key is read server-side only and is
# REQUIRED in production for the model you use (the endpoint fails fast if unset;
# in dev it only warns). OpenAI is the default provider (default model: gpt-4o-mini).
OPENAI_API_KEY=
# Optional — only needed if you switch the assistant to a Claude model.
# ANTHROPIC_API_KEY=
